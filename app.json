{
  "expo": {
    "name": "PRITECH Task Manager",
    "slug": "pritech-task-manager",
    "owner": "enisgjini20",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pritechtaskmanager",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pritech.taskmanager",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1128",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.pritech.taskmanager"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.jpg",
          "imageWidth": 260,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/logo.jpg",
            "imageWidth": 260
          },
          "ios": {
            "image": "./assets/images/logo.jpg",
            "imageWidth": 260
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "6f1eed8a-f397-4659-b904-9dd506542eb5"
      }
    }
  }
}
