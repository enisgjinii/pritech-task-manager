{
  "expo": {
    "name": "PRITECH Task Manager",
    "slug": "pritech-task-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pritechtaskmanager",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pritech.taskmanager"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B2A4A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.pritech.taskmanager"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B2A4A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ]
  }
}
